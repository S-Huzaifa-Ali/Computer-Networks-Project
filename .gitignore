# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# ─── Virtual environments ─────────────────────────────────────────────────────
venv/
.venv/
env/
.env/
ENV/

# ─── TLS / SSL certificates (generated by certs/generate_certs.py) ────────────
CN-PROJECT/certs/server.crt
CN-PROJECT/certs/server.key
*.crt
*.key
*.pem

# ─── Database (runtime-generated) ─────────────────────────────────────────────
CN-PROJECT/data/smtp_server.db
*.db
*.sqlite
*.sqlite3

# ─── Runtime data files ───────────────────────────────────────────────────────
CN-PROJECT/data/last_login.json

# ─── Logs ─────────────────────────────────────────────────────────────────────
CN-PROJECT/logs/*.log
*.log
!CN-PROJECT/logs/.gitkeep

# ─── Environment / secrets ────────────────────────────────────────────────────
.env
.env.*
secrets.json

# ─── IDE / editor ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ─── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── Pytest / coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml
